{
  "permissions": {
    "allow": [
      "Bash(git push *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git config *)",
      "Bash(git commit *)"
    ]
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com"
      ]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/user/hipermascotarafaelaweb && git config commit.gpgSign false 2>/dev/null || true",
            "statusMessage": "Setting up git configuration for automatic commits..."
          }
        ]
      }
    ]
  },
  "env": {
    "GIT_AUTHOR_NAME": "Claude",
    "GIT_AUTHOR_EMAIL": "noreply@anthropic.com",
    "GIT_COMMITTER_NAME": "Claude",
    "GIT_COMMITTER_EMAIL": "noreply@anthropic.com"
  }
}
